# Apex Environment Configuration
# ================================
# Copy this file to .env.local and fill in your values

# =============================================================================
# CLERK AUTHENTICATION (Required for production)
# =============================================================================
# Get your keys from https://dashboard.clerk.com
# Set to "pk_test_placeholder" to run in dev mode without authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder

# Clerk URLs (optional - defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# =============================================================================
# DATABASE (Required for production, optional for dev)
# =============================================================================
# Neon PostgreSQL connection string
# In dev mode without DATABASE_URL, APIs return mock data
DATABASE_URL=postgresql://user:password@host:5432/apex

# =============================================================================
# ENCRYPTION KEY (Required for API key storage)
# =============================================================================
# AES-256-GCM encryption key for securing API keys at rest
# IMPORTANT: Generate a unique 64-character hex key for each environment
# NEVER commit actual keys to version control!
#
# Generate a secure key using one of these commands:
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   OpenSSL: openssl rand -hex 32
#   Python:  python -c "import secrets; print(secrets.token_hex(32))"
#
# Format: 64 hexadecimal characters (0-9, a-f) representing 32 bytes
# Example: a1b2c3d4e5f6....(64 chars total)
#
# In development mode only: If not set, a fallback key is used (NOT SECURE!)
# In production: Application will fail to start without this key
ENCRYPTION_KEY=

# =============================================================================
# REDIS (Optional - for caching and job queues)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# AI SERVICES (Required for Engine Room - AI platform monitoring)
# =============================================================================
# These API keys enable the Engine Room to query AI platforms and collect
# brand mentions automatically. At least one key is required for Engine Room.
#
# OpenAI (ChatGPT) - Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) - Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google AI (Gemini) - Get your key from https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Perplexity - Get your key from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# DeepSeek - Get your key from https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Note: Grok and Copilot APIs not yet available

# =============================================================================
# SOCIAL MEDIA APIs (Optional - for social media tracking features)
# =============================================================================
# Twitter/X API Bearer Token
# Get your token from https://developer.twitter.com/en/portal/dashboard
# Required for fetching Twitter mentions and social tracking features
# 1. Create a Twitter Developer account at https://developer.twitter.com
# 2. Create a new Project and App in the Developer Portal
# 3. Generate a Bearer Token under "Keys and Tokens"
TWITTER_BEARER_TOKEN=

# =============================================================================
# PAYFAST (Required for payments/subscriptions)
# =============================================================================
# Get your credentials from https://my.payfast.io/settings/developer-settings
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# Set to "true" for sandbox/testing mode
PAYFAST_SANDBOX=false

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development

# =============================================================================
# ADMIN PANEL (Development only)
# =============================================================================
# Set to "true" to enable super-admin access in development mode
# This allows access to /admin/* routes without Clerk authentication
DEV_SUPER_ADMIN=true
# Bugsink error tracking (inert unless SENTRY_ENABLED=true)
SENTRY_ENABLED=false
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=
# GIT_SHA / NEXT_PUBLIC_GIT_SHA — set by deploy for release tagging
# SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT — CI source map upload
