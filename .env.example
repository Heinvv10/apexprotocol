# Apex Environment Configuration
# ================================
# Copy this file to .env.local and fill in your values

# =============================================================================
# CLERK AUTHENTICATION (Required for production)
# =============================================================================
# Get your keys from https://dashboard.clerk.com
# Set to "pk_test_placeholder" to run in dev mode without authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder

# Clerk URLs (optional - defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# =============================================================================
# DATABASE (Required for production, optional for dev)
# =============================================================================
# Neon PostgreSQL connection string
# In dev mode without DATABASE_URL, APIs return mock data
DATABASE_URL=postgresql://user:password@host:5432/apex

# =============================================================================
# REDIS (Optional - for caching and job queues)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# AI SERVICES (Optional - for AI-powered features)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development
