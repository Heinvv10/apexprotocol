# =====================================================================
# Apex App — Velo Server Environment (Plan 5)
# Copy this to .env.velo and fill in real values.
# NEVER commit .env.velo to git.
# =====================================================================

# --- Supabase (from apexgeo-supabase stack) ---
# Public URL = Kong gateway exposed via Cloudflare
NEXT_PUBLIC_SUPABASE_URL=https://api.apexgeo.app
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from apexgeo-supabase .env ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<from apexgeo-supabase .env SERVICE_ROLE_KEY>
SUPABASE_JWT_SECRET=<from apexgeo-supabase .env JWT_SECRET>

# --- Database (direct to Supabase postgres within apexgeo_network) ---
DATABASE_URL=postgresql://postgres:<POSTGRES_PASSWORD>@apexgeo-supabase-db:5432/apexgeo
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# --- Application ---
NEXT_PUBLIC_APP_URL=https://apexgeo.app

# --- AI APIs ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Vector DB ---
PINECONE_API_KEY=
PINECONE_INDEX=apex-geo

# --- Error Tracking (optional) ---
SENTRY_ENABLED=false
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=

# --- Git SHA (set by deploy script) ---
GIT_SHA=
NEXT_PUBLIC_GIT_SHA=
