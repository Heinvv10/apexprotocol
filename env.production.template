# Apex Production Environment Configuration
# ================================
# For VPS deployment at 72.61.197.178
# Copy this to .env.production and fill in your actual values

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://72.61.197.178

# =============================================================================
# CLERK AUTHENTICATION (REQUIRED)
# =============================================================================
# Get your production keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX
CLERK_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# Neon PostgreSQL connection string
# Format: postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=postgresql://XXXXX:XXXXX@XXXXX.neon.tech:5432/apex?sslmode=require

# =============================================================================
# ENCRYPTION KEY (REQUIRED - CRITICAL FOR SECURITY)
# =============================================================================
# Generate a secure 64-character hex key:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# REDIS (Optional but recommended for production)
# =============================================================================
# Upstash Redis for caching and job queues
# Get from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://XXXXX.upstash.io
UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXXXXXXXX

# =============================================================================
# AI SERVICES (At least ONE required for Engine Room)
# =============================================================================
# OpenAI (ChatGPT) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google AI (Gemini) - https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Perplexity - https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# DeepSeek - https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# VECTOR DATABASE (Optional - for semantic search)
# =============================================================================
# Pinecone - Get from https://app.pinecone.io/
PINECONE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PINECONE_INDEX=apex-production

# =============================================================================
# STRIPE (Optional - for subscription management)
# =============================================================================
# Stripe API keys - Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=REDACTED_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# SOCIAL MEDIA APIs (Optional)
# =============================================================================
# Twitter/X API - https://developer.twitter.com/
TWITTER_BEARER_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# CRM & MARKETING INTEGRATIONS (Optional)
# =============================================================================
# Mautic CRM - Your Mautic installation
MAUTIC_BASE_URL=https://your-mautic.com
MAUTIC_CLIENT_ID=XXXXX
MAUTIC_CLIENT_SECRET=XXXXX
MAUTIC_USERNAME=admin@example.com
MAUTIC_PASSWORD=XXXXX

# ListMonk Email - Your ListMonk installation
LISTMONK_BASE_URL=https://your-listmonk.com
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=XXXXX

# Postiz Social Media - Your Postiz installation
POSTIZ_BASE_URL=https://your-postiz.com
POSTIZ_API_KEY=XXXXX

# =============================================================================
# MONITORING & LOGGING (Optional)
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=https://XXXXX@sentry.io/XXXXX

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Domain for Nginx (optional)
DOMAIN=apex.yourdomain.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. NEVER commit this file with real values to version control
# 2. Always use strong, unique passwords for production
# 3. Rotate secrets regularly
# 4. Use environment-specific keys (don't reuse dev keys in production)
# 5. Enable 2FA on all service accounts
# 6. Restrict API key permissions to minimum required
# 7. Monitor API usage for unusual patterns
# 8. Keep backup of this file in a secure location (password manager)
